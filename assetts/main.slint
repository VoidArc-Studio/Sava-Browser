import { Theme } from "styles.slint";

export component AppWindow inherits Window {
    width: 1280px;
    height: 720px;
    title: "Sava Browser";
    background: AppTheme.current-theme.background;

    // Pasek boczny
    Rectangle {
        width: 60px;
        height: parent.height;
        background: AppTheme.current-theme.secondary-color;
        VerticalLayout {
            spacing: 10px;
            padding: 10px;
            Image {
                source: @image-url("icons/bookmarks.svg");
                width: 40px;
                height: 40px;
                clicked => { bookmarks_popup.visible = true; }
            }
            Image {
                source: @image-url("icons/history.svg");
                width: 40px;
                height: 40px;
                clicked => { history_popup.visible = true; }
            }
            Image {
                source: @image-url("icons/settings.svg");
                width: 40px;
                height: 40px;
                clicked => { settings_popup.visible = true; }
            }
        }
    }

    // Pasek kart i adresu
    Rectangle {
        x: 60px;
        width: parent.width - 60px;
        height: 60px;
        background: AppTheme.current-theme.primary-color;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        HorizontalLayout {
            spacing: 8px;
            padding: 8px;

            // Przycisk nowej karty
            Button {
                text: "+";
                width: 40px;
                height: 40px;
                background: AppTheme.current-theme.accent-color;
                border-radius: AppTheme.current-theme.border-radius;
                clicked => { root.new_tab(); }
            }

            // Dynamiczne karty
            for tab in ["Tab 1", "Tab 2"]: Rectangle {
                width: 150px;
                height: 40px;
                background: AppTheme.current-theme.secondary-color;
                border-radius: AppTheme.current-theme.border-radius;
                drop-shadow: 0px 1px 3px AppTheme.current-theme.shadow-color;
                HorizontalLayout {
                    Text {
                        text: tab;
                        color: AppTheme.current-theme.text-color;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        font-size: 14px;
                    }
                    Button {
                        text: "x";
                        width: 20px;
                        height: 20px;
                        background: transparent;
                        color: AppTheme.current-theme.text-color;
                        clicked => { root.close_tab(index); }
                    }
                }
                TouchArea {
                    clicked => { /* TODO: Przełącz kartę */ }
                }
            }

            // Pasek adresu
            Rectangle {
                width: parent.width - 350px;
                height: 40px;
                background: AppTheme.current-theme.background;
                border-radius: AppTheme.current-theme.border-radius;
                border-width: 1px;
                border-color: #dadce0;
                drop-shadow: 0px 1px 2px AppTheme.current-theme.shadow-color;

                TextInput {
                    id: url_bar;
                    placeholder-text: "Search or enter URL";
                    width: parent.width - 10px;
                    height: parent.height - 10px;
                    font-size: 16px;
                    color: AppTheme.current-theme.text-color;
                    accepted => { root.open_url(url_bar.text); }
                }
            }

            // Przyciski
            HorizontalLayout {
                spacing: 5px;
                Button {
                    text: "AI";
                    width: 50px;
                    height: 40px;
                    background: AppTheme.current-theme.accent-color;
                    border-radius: AppTheme.current-theme.border-radius;
                    clicked => { ai_popup.visible = true; }
                }
                Button {
                    text: "Incognito";
                    width: 80px;
                    height: 40px;
                    background: AppTheme.current-theme.accent-color;
                    border-radius: AppTheme.current-theme.border-radius;
                    clicked => { root.toggle_incognito(); }
                }
                Button {
                    text: "☆";
                    width: 40px;
                    height: 40px;
                    background: AppTheme.current-theme.accent-color;
                    border-radius: AppTheme.current-theme.border-radius;
                    clicked => { root.add_bookmark(url_bar.text); }
                }
                Button {
                    text: "☰";
                    width: 40px;
                    height: 40px;
                    background: AppTheme.current-theme.accent-color;
                    border-radius: AppTheme.current-theme.border-radius;
                    clicked => { menu_popup.visible = true; }
                }
            }
        }
    }

    // Obszar WebView
    Rectangle {
        x: 60px;
        y: 60px;
        width: parent.width - 60px;
        height: parent.height - 60px;
        background: #ffffff;
        // TODO: Osadzenie WebView
    }

    // Popup asystenta AI
    PopupWindow {
        id: ai_popup;
        width: 400px;
        height: 320px;
        x: parent.width - 410px;
        y: 70px;
        visible: false;
        background: AppTheme.current-theme.background;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        VerticalLayout {
            spacing: 10px;
            padding: 10px;
            Text {
                text: "Sava AI Assistant";
                font-size: 18px;
                color: AppTheme.current-theme.text-color;
            }
            ComboBox {
                id: ai_mode;
                model: ["Conversation", "Web Search", "Developer Mode"];
                current-index: 0;
                width: parent.width - 20px;
            }
            TextInput {
                id: ai_query;
                placeholder-text: "Ask Sava AI...";
                width: parent.width - 20px;
                font-size: 14px;
            }
            Button {
                text: "Send";
                background: AppTheme.current-theme.primary-color;
                color: AppTheme.current-theme.text-color;
                border-radius: AppTheme.current-theme.border-radius;
                clicked => {
                    root.ai_request(ai_query.text, ai_mode.current-index);
                    ai_popup.visible = false;
                }
            }
        }
    }

    // Menu ustawień
    PopupWindow {
        id: menu_popup;
        width: 220px;
        height: 300px;
        x: parent.width - 230px;
        y: 70px;
        visible: false;
        background: AppTheme.current-theme.background;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        VerticalLayout {
            spacing: 5px;
            padding: 5px;
            Button {
                text: "Settings";
                clicked => { settings_popup.visible = true; }
            }
            Button {
                text: "View Bookmarks";
                clicked => { bookmarks_popup.visible = true; }
            }
            Button {
                text: "View History";
                clicked => { history_popup.visible = true; }
            }
            Button {
                text: "Clear Cookies";
                clicked => { /* TODO: Wyczyść ciasteczka */ }
            }
            Button {
                text: "Toggle Dark Mode";
                clicked => { AppTheme.change-theme("dark"); }
            }
            Button {
                text: "Exit";
                clicked => { root.close(); }
            }
        }
    }

    // Popup zakładek
    PopupWindow {
        id: bookmarks_popup;
        width: 300px;
        height: 400px;
        x: 70px;
        y: 70px;
        visible: false;
        background: AppTheme.current-theme.background;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        VerticalLayout {
            spacing: 5px;
            padding: 5px;
            Text {
                text: "Bookmarks";
                font-size: 18px;
                color: AppTheme.current-theme.text-color;
            }
            // TODO: Dynamiczna lista zakładek
        }
    }

    // Popup historii
    PopupWindow {
        id: history_popup;
        width: 300px;
        height: 400px;
        x: 70px;
        y: 70px;
        visible: false;
        background: AppTheme.current-theme.background;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        VerticalLayout {
            spacing: 5px;
            padding: 5px;
            Text {
                text: "History";
                font-size: 18px;
                color: AppTheme.current-theme.text-color;
            }
            // TODO: Dynamiczna lista historii
        }
    }

    // Popup ustawień
    PopupWindow {
        id: settings_popup;
        width: 400px;
        height: 500px;
        x: 70px;
        y: 70px;
        visible: false;
        background: AppTheme.current-theme.background;
        border-radius: AppTheme.current-theme.border-radius;
        drop-shadow: 0px 2px 5px AppTheme.current-theme.shadow-color;

        VerticalLayout {
            spacing: 10px;
            padding: 10px;
            Text {
                text: "Settings";
                font-size: 18px;
                color: AppTheme.current-theme.text-color;
            }
            CheckBox {
                text: "Block Ads";
                checked: true;
            }
            CheckBox {
                text: "Block JavaScript";
                checked: false;
            }
            Text {
                text: "Homepage";
                color: AppTheme.current-theme.text-color;
            }
            TextInput {
                placeholder-text: "Enter homepage URL";
                width: parent.width - 20px;
            }
        }
    }

    callback open_url(string);
    callback new_tab();
    callback close_tab(int);
    callback toggle_incognito();
    callback add_bookmark(string);
    callback ai_request(string, int);
}
